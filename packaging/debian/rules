#!/usr/bin/make -f
# Debian rules file for quadletman

export DH_VERBOSE = 1

# dh sets DESTDIR to debian/<package> automatically in dh_auto_install
PACKAGE  := quadletman
STAGING  := $(CURDIR)/debian/$(PACKAGE)
BUILD_VENV := $(CURDIR)/debian/quadletman-build-venv

%:
	dh $@

override_dh_auto_build:
	# Build a Python wheel from source.  The wheel is pure Python — C extension
	# dependencies are installed from PyPI on the target system during postinst.
	python3 -m venv $(BUILD_VENV)
	$(BUILD_VENV)/bin/pip install \
		--quiet --no-cache-dir --disable-pip-version-check \
		hatchling hatch-vcs build
	$(BUILD_VENV)/bin/python -m build --wheel --no-isolation \
		--outdir $(CURDIR)/debian/wheel $(CURDIR)

override_dh_auto_install:
	# Ship the wheel — the venv is created at install time in postinst
	install -d $(STAGING)/usr/share/quadletman
	cp $(CURDIR)/debian/wheel/quadletman-*.whl \
		$(STAGING)/usr/share/quadletman/

	# Wrapper script at /usr/bin/quadletman
	install -d $(STAGING)/usr/bin
	printf '#!/bin/bash\nVENV=/usr/lib/quadletman/venv\nfor _sp in "$$VENV"/lib/python*/site-packages; do\n    [ -d "$$_sp" ] || continue\n    export PYTHONPATH="$$_sp$${PYTHONPATH:+:$$PYTHONPATH}"\n    break\ndone\nexec "$$VENV/bin/python3" -m quadletman "$$@"\n' \
		> $(STAGING)/usr/bin/quadletman
	chmod 0755 $(STAGING)/usr/bin/quadletman

	# systemd unit (into /lib/systemd/system/ per Debian convention)
	install -D -m 0644 $(CURDIR)/quadletman.service \
		$(STAGING)/lib/systemd/system/quadletman.service

	# Sudoers file (shipped to /usr/share, installed to /etc in postinst)
	install -D -m 0440 $(CURDIR)/packaging/sudoers.d/quadletman \
		$(STAGING)/usr/share/quadletman/sudoers.d/quadletman

	# PAM service configuration
	install -D -m 0644 $(CURDIR)/packaging/pam.d/quadletman \
		$(STAGING)/etc/pam.d/quadletman

	# Default environment file
	install -D -m 0640 $(CURDIR)/packaging/quadletman.env \
		$(STAGING)/etc/quadletman/quadletman.env

	# State directories — created by postinst; list them for dh_installdirs
	install -d $(STAGING)/var/lib/quadletman/volumes

override_dh_auto_clean:
	rm -rf $(BUILD_VENV) $(CURDIR)/debian/wheel

# dh_python3 is not used — bundled venv manages its own Python packages
