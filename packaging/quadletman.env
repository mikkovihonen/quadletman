# /etc/quadletman/quadletman.env — quadletman configuration
#
# This file is read by the quadletman systemd unit on startup.
# Uncomment and modify settings as needed, then restart the service:
#   sudo systemctl restart quadletman
#
# See the runbook for full documentation of all settings:
#   https://github.com/mikkovihonen/quadletman/blob/main/docs/runbook.md

# --- Network ---
# QUADLETMAN_HOST=0.0.0.0
# QUADLETMAN_PORT=8080
# QUADLETMAN_UNIX_SOCKET=

# --- Logging ---
# QUADLETMAN_LOG_LEVEL=INFO

# --- Storage ---
# QUADLETMAN_DB_PATH=/var/lib/quadletman/quadletman.db
# QUADLETMAN_VOLUMES_BASE=/var/lib/quadletman/volumes

# --- Security ---
# QUADLETMAN_SECURE_COOKIES=false
# QUADLETMAN_ALLOWED_GROUPS=sudo,wheel
# QUADLETMAN_SESSION_TTL=28800

# --- Monitoring ---
# QUADLETMAN_POLL_INTERVAL=30
# QUADLETMAN_PROCESS_MONITOR_INTERVAL=60
# QUADLETMAN_CONNECTION_MONITOR_INTERVAL=60
# QUADLETMAN_IMAGE_UPDATE_CHECK_INTERVAL=21600
# QUADLETMAN_METRICS_INTERVAL=300
# QUADLETMAN_METRICS_RETENTION_HOURS=168

# --- Timeouts ---
# QUADLETMAN_SUBPROCESS_TIMEOUT=30
# QUADLETMAN_IMAGE_PULL_TIMEOUT=300
# QUADLETMAN_LOCK_TIMEOUT=30

# --- Webhooks ---
# QUADLETMAN_WEBHOOK_TIMEOUT=10
# QUADLETMAN_WEBHOOK_MAX_RETRIES=3

# --- UI ---
# QUADLETMAN_UI_POLL_INTERVAL=5
# QUADLETMAN_UI_DISK_POLL_INTERVAL=60
